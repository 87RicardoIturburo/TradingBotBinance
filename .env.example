# ⚠️ NUNCA commitear este archivo con valores reales
# Copiar como .env y llenar con las credenciales correspondientes

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# API
API_PORT=8080

# Binance — NUNCA usar credenciales de producción sin verificar UseTestnet=true
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_USE_TESTNET=true
BINANCE_USE_DEMO=false

# Autenticación API — Si vacío, la API funciona sin autenticación (solo desarrollo)
TRADINGBOT_API_KEY=
