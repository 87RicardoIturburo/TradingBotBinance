@page "/metrics"
@inject TradingApiClient Api
@inject IConfiguration Config
@implements IAsyncDisposable

<PageTitle>Métricas — TradingBot</PageTitle>

<h1>📈 Dashboard de Métricas</h1>

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@* ── Circuit Breaker ──────────────────────────────────────────────────── *@
@if (snapshot?.CircuitBreakerOpen == true)
{
    <div class="alert alert-danger d-flex align-items-center mb-3">
        <strong class="me-2">🚨 Circuit Breaker ABIERTO</strong>
        <span>@snapshot.CircuitBreakerReason</span>
    </div>
}

@* ── Tarjetas principales ────────────────────────────────────────────── *@
<div class="row mb-4">
    <div class="col-md-3 mb-2">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-title text-muted">Ticks procesados</h6>
                <span class="fs-3 fw-bold">@FormatNumber(snapshot?.TotalTicksProcessed ?? 0)</span>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-2">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-title text-muted">Señales generadas</h6>
                <span class="fs-3 fw-bold text-primary">@FormatNumber(snapshot?.TotalSignalsGenerated ?? 0)</span>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-2">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-title text-muted">Órdenes colocadas</h6>
                <span class="fs-3 fw-bold text-success">@FormatNumber(snapshot?.TotalOrdersPlaced ?? 0)</span>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-2">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-title text-muted">Órdenes rechazadas</h6>
                <span class="fs-3 fw-bold text-danger">@FormatNumber(snapshot?.TotalOrdersFailed ?? 0)</span>
            </div>
        </div>
    </div>
</div>

@* ── Desglose de órdenes y latencia ──────────────────────────────────── *@
<div class="row mb-4">
    <div class="col-md-4 mb-2">
        <div class="card">
            <div class="card-header"><strong>📊 Desglose de órdenes</strong></div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span>Live</span>
                    <strong>@FormatNumber(snapshot?.TotalOrdersLive ?? 0)</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Paper</span>
                    <strong>@FormatNumber(snapshot?.TotalOrdersPaper ?? 0)</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Rechazadas</span>
                    <strong class="text-danger">@FormatNumber(snapshot?.TotalOrdersFailed ?? 0)</strong>
                </div>
                @{
                    var total = (snapshot?.TotalOrdersPlaced ?? 0) + (snapshot?.TotalOrdersFailed ?? 0);
                    var successRate = total > 0
                        ? (double)(snapshot?.TotalOrdersPlaced ?? 0) / total * 100
                        : 0;
                }
                <hr />
                <div class="d-flex justify-content-between">
                    <span>Tasa de éxito</span>
                    <strong class="@(successRate >= 80 ? "text-success" : successRate >= 50 ? "text-warning" : "text-danger")">
                        @successRate.ToString("N1")%
                    </strong>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-2">
        <div class="card">
            <div class="card-header"><strong>⚡ Latencia tick→orden</strong></div>
            <div class="card-body text-center">
                <div class="mb-3">
                    <small class="text-muted">Última</small>
                    <div class="fs-3 fw-bold @LatencyCssClass(snapshot?.LastLatencyMs ?? 0)">
                        @((snapshot?.LastLatencyMs ?? 0).ToString("N1")) ms
                    </div>
                </div>
                <div>
                    <small class="text-muted">Promedio</small>
                    <div class="fs-4 @LatencyCssClass(snapshot?.AverageLatencyMs ?? 0)">
                        @((snapshot?.AverageLatencyMs ?? 0).ToString("N1")) ms
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-2">
        <div class="card">
            <div class="card-header"><strong>💰 P&amp;L diario</strong></div>
            <div class="card-body text-center">
                @{
                    var pnl = snapshot?.DailyPnLUsdt ?? 0;
                }
                <div class="fs-2 fw-bold @(pnl >= 0 ? "text-success" : "text-danger")">
                    @((pnl >= 0 ? "+" : "") + pnl.ToString("N2")) USDT
                </div>
            </div>
        </div>
    </div>
</div>

@* ── Ticks descartados ───────────────────────────────────────────────── *@
<div class="row mb-4">
    <div class="col-md-6 mb-2">
        <div class="card">
            <div class="card-header"><strong>🗑️ Ticks descartados (DropOldest)</strong></div>
            <div class="card-body text-center">
                @{
                    var dropped = snapshot?.TotalTicksDropped ?? 0;
                    var processed = snapshot?.TotalTicksProcessed ?? 0;
                    var dropRate = processed > 0 ? (double)dropped / (processed + dropped) * 100 : 0;
                }
                <div class="fs-3 fw-bold @(dropped > 0 ? "text-warning" : "text-success")">
                    @FormatNumber(dropped)
                </div>
                <small class="text-muted">
                    @(dropped > 0 ? $"Drop rate: {dropRate:N2}%" : "Sin pérdida de datos")
                </small>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-2">
        <div class="card">
            <div class="card-header">
                <strong>📡 Actualización en tiempo real</strong>
                @if (hubState == "Connected")
                {
                    <span class="badge bg-success ms-2">SignalR ✓</span>
                }
                else
                {
                    <span class="badge bg-warning ms-2">@hubState</span>
                }
            </div>
            <div class="card-body text-center">
                @if (snapshot is not null)
                {
                    <small class="text-muted">
                        Última actualización: @snapshot.Timestamp.ToLocalTime().ToString("HH:mm:ss")
                    </small>
                }
                else
                {
                    <small class="text-muted">Esperando datos…</small>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private MetricsSnapshotDto? snapshot;
    private HubConnection? hubConnection;
    private string hubState = "Disconnected";
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadMetricsAsync();
        await StartSignalRAsync();
    }

    private async Task LoadMetricsAsync()
    {
        try
        {
            snapshot = await Api.GetMetricsAsync();
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al obtener métricas: {ex.Message}";
        }
    }

    private async Task StartSignalRAsync()
    {
        try
        {
            var apiUrl = Config["ApiBaseUrl"] ?? "https://localhost:7114";

            hubConnection = new HubConnectionBuilder()
                .WithUrl($"{apiUrl}/hubs/trading", options =>
                {
                    options.HttpMessageHandlerFactory = innerHandler =>
                        new CookieDelegatingHandler { InnerHandler = innerHandler };
                })
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<MetricsSnapshotDto>("OnMetricsUpdate", metricsDto =>
            {
                snapshot = metricsDto;
                InvokeAsync(StateHasChanged);
            });

            hubConnection.Reconnecting += _ =>
            {
                hubState = "Reconnecting…";
                InvokeAsync(StateHasChanged);
                return Task.CompletedTask;
            };

            hubConnection.Reconnected += _ =>
            {
                hubState = "Connected";
                InvokeAsync(StateHasChanged);
                return Task.CompletedTask;
            };

            hubConnection.Closed += _ =>
            {
                hubState = "Disconnected";
                InvokeAsync(StateHasChanged);
                return Task.CompletedTask;
            };

            await hubConnection.StartAsync();
            hubState = "Connected";
        }
        catch (Exception ex)
        {
            hubState = "Error";
            errorMessage = $"SignalR: {ex.Message}";
        }
    }

    private static string FormatNumber(long value) => value switch
    {
        >= 1_000_000 => $"{value / 1_000_000.0:N1}M",
        >= 1_000     => $"{value / 1_000.0:N1}K",
        _            => value.ToString("N0")
    };

    private static string LatencyCssClass(double ms) => ms switch
    {
        <= 50  => "text-success",
        <= 200 => "text-warning",
        _      => "text-danger"
    };

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
            await hubConnection.DisposeAsync();
    }
}
