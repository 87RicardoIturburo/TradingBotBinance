@page "/positions"
@inject TradingApiClient Api

<PageTitle>P&amp;L y Posiciones — TradingBot</PageTitle>

<h1>💰 P&amp;L y Posiciones</h1>

@* ── Resumen P&L por estrategia ──────────────────────────────────────── *@
<h4 class="mt-3">📊 Resumen por estrategia</h4>

@if (summary is null)
{
    <p class="text-muted">Cargando resumen…</p>
}
else if (summary.Count == 0)
{
    <div class="alert alert-info">No hay estrategias creadas.</div>
}
else
{
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h6 class="text-muted">P&amp;L Diario Realizado</h6>
                    <span class="fs-4 fw-bold @GetPnLClass(summary.Sum(s => s.DailyRealizedPnL))">
                        @FormatPnL(summary.Sum(s => s.DailyRealizedPnL))
                    </span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h6 class="text-muted">P&amp;L No Realizado</h6>
                    <span class="fs-4 fw-bold @GetPnLClass(summary.Sum(s => s.UnrealizedPnL))">
                        @FormatPnL(summary.Sum(s => s.UnrealizedPnL))
                    </span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h6 class="text-muted">P&amp;L Total Realizado</h6>
                    <span class="fs-4 fw-bold @GetPnLClass(summary.Sum(s => s.TotalRealizedPnL))">
                        @FormatPnL(summary.Sum(s => s.TotalRealizedPnL))
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Estrategia</th>
                    <th>Símbolo</th>
                    <th>Pos. Abiertas</th>
                    <th>P&amp;L No Realizado</th>
                    <th>P&amp;L Diario</th>
                    <th>P&amp;L Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in summary)
                {
                    <tr>
                        <td><strong>@s.StrategyName</strong></td>
                        <td>@s.Symbol</td>
                        <td>@s.OpenPositions</td>
                        <td class="@GetPnLClass(s.UnrealizedPnL)">@FormatPnL(s.UnrealizedPnL)</td>
                        <td class="@GetPnLClass(s.DailyRealizedPnL)">@FormatPnL(s.DailyRealizedPnL)</td>
                        <td class="fw-bold @GetPnLClass(s.TotalRealizedPnL)">@FormatPnL(s.TotalRealizedPnL)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@* ── Posiciones abiertas ─────────────────────────────────────────────── *@
<h4 class="mt-4">📂 Posiciones abiertas</h4>

@if (openPositions is null)
{
    <p class="text-muted">Cargando…</p>
}
else if (openPositions.Count == 0)
{
    <div class="alert alert-secondary">No hay posiciones abiertas.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Apertura</th>
                    <th>Símbolo</th>
                    <th>Lado</th>
                    <th>Cantidad</th>
                    <th>Precio Entrada</th>
                    <th>Precio Actual</th>
                    <th>P&amp;L</th>
                    <th>P&amp;L %</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in openPositions)
                {
                    <tr>
                        <td>@p.OpenedAt.ToLocalTime().ToString("dd/MM HH:mm:ss")</td>
                        <td><strong>@p.Symbol</strong></td>
                        <td>
                            <span class="badge @(p.Side == "Buy" ? "bg-success" : "bg-danger")">
                                @p.Side
                            </span>
                        </td>
                        <td>@p.Quantity.ToString("N6")</td>
                        <td>@p.EntryPrice.ToString("N2")</td>
                        <td>@p.CurrentPrice.ToString("N2")</td>
                        <td class="fw-bold @GetPnLClass(p.UnrealizedPnL)">
                            @FormatPnL(p.UnrealizedPnL)
                        </td>
                        <td class="@GetPnLClass(p.UnrealizedPnLPercent)">
                            @p.UnrealizedPnLPercent.ToString("N2")%
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@* ── Posiciones cerradas (historial) ─────────────────────────────────── *@
<h4 class="mt-4">📜 Historial de posiciones cerradas</h4>

<div class="row mb-3">
    <div class="col-md-3">
        <label class="form-label">Desde</label>
        <InputDate class="form-control" @bind-Value="fromDate" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Hasta</label>
        <InputDate class="form-control" @bind-Value="toDate" />
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <button class="btn btn-primary" @onclick="LoadClosedPositionsAsync">🔍 Buscar</button>
    </div>
</div>

@if (closedPositions is null)
{
    <p class="text-muted">Cargando…</p>
}
else if (closedPositions.Count == 0)
{
    <div class="alert alert-secondary">No hay posiciones cerradas en el rango.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Apertura</th>
                    <th>Cierre</th>
                    <th>Símbolo</th>
                    <th>Lado</th>
                    <th>Cantidad</th>
                    <th>Entrada</th>
                    <th>Salida</th>
                    <th>P&amp;L Realizado</th>
                    <th>Resultado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in closedPositions)
                {
                    <tr>
                        <td>@p.OpenedAt.ToLocalTime().ToString("dd/MM HH:mm")</td>
                        <td>@p.ClosedAt?.ToLocalTime().ToString("dd/MM HH:mm")</td>
                        <td><strong>@p.Symbol</strong></td>
                        <td>
                            <span class="badge @(p.Side == "Buy" ? "bg-success" : "bg-danger")">
                                @p.Side
                            </span>
                        </td>
                        <td>@p.Quantity.ToString("N6")</td>
                        <td>@p.EntryPrice.ToString("N2")</td>
                        <td>@p.CurrentPrice.ToString("N2")</td>
                        <td class="fw-bold @GetPnLClass(p.RealizedPnL ?? 0)">
                            @FormatPnL(p.RealizedPnL ?? 0)
                        </td>
                        <td>
                            @if (p.RealizedPnL > 0)
                            {
                                <span class="badge bg-success">✅ Ganancia</span>
                            }
                            else if (p.RealizedPnL < 0)
                            {
                                <span class="badge bg-danger">❌ Pérdida</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">➖ Break-even</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="row mt-2">
        <div class="col-md-3">
            <strong>Total P&amp;L:</strong>
            <span class="@GetPnLClass(ClosedTotalPnL) fw-bold">@FormatPnL(ClosedTotalPnL)</span>
        </div>
        <div class="col-md-3">
            <strong>Trades:</strong> @closedPositions.Count
            (<span class="text-success">@ClosedWins W</span> / <span class="text-danger">@ClosedLosses L</span>)
        </div>
        <div class="col-md-3">
            <strong>Win rate:</strong>
            @if (closedPositions.Count > 0)
            {
                @((ClosedWins * 100.0 / closedPositions.Count).ToString("N1"))@:%
            }
            else
            {
                <span>—</span>
            }
        </div>
    </div>
}

@if (errorMessage is not null)
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@code {
    private List<PnLSummaryDto>? summary;
    private List<PositionDto>? openPositions;
    private List<PositionDto>? closedPositions;
    private string? errorMessage;
    private DateTime fromDate = DateTime.UtcNow.AddDays(-30).Date;
    private DateTime toDate = DateTime.UtcNow.Date.AddDays(1);

    private decimal ClosedTotalPnL => closedPositions?.Sum(p => p.RealizedPnL ?? 0) ?? 0;
    private int ClosedWins => closedPositions?.Count(p => p.RealizedPnL > 0) ?? 0;
    private int ClosedLosses => closedPositions?.Count(p => p.RealizedPnL < 0) ?? 0;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            LoadSummaryAsync(),
            LoadOpenPositionsAsync(),
            LoadClosedPositionsAsync());
    }

    private async Task LoadSummaryAsync()
    {
        try
        {
            summary = await Api.GetPnLSummaryAsync() ?? [];
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar resumen: {ex.Message}";
        }
    }

    private async Task LoadOpenPositionsAsync()
    {
        try
        {
            openPositions = await Api.GetOpenPositionsAsync() ?? [];
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar posiciones abiertas: {ex.Message}";
        }
    }

    private async Task LoadClosedPositionsAsync()
    {
        try
        {
            closedPositions = await Api.GetClosedPositionsAsync(
                new DateTimeOffset(fromDate, TimeSpan.Zero),
                new DateTimeOffset(toDate, TimeSpan.Zero)) ?? [];
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar historial: {ex.Message}";
        }
    }

    private static string GetPnLClass(decimal value) => value switch
    {
        > 0 => "text-success",
        < 0 => "text-danger",
        _   => "text-muted"
    };

    private static string FormatPnL(decimal value) =>
        $"{(value >= 0 ? "+" : "")}{value:N2} USDT";
}
