@page "/symbol-pool"
@inject TradingApiClient Api
@inject IConfiguration Config
@implements IAsyncDisposable

<PageTitle>AutoPilot v2 — Symbol Pool</PageTitle>

<div class="d-flex align-items-center mb-3">
    <h1 class="mb-0 me-3">🎯 AutoPilot v2 — Symbol Pool</h1>
    <div class="form-check form-switch fs-4 ms-auto">
        <input class="form-check-input" type="checkbox" id="poolToggle"
               checked="@_enabled" @onchange="TogglePoolAsync" disabled="@_toggling" />
        <label class="form-check-label" for="poolToggle">
            <span class="badge @(_enabled ? "bg-success" : "bg-secondary") fs-6">
                @(_enabled ? "ACTIVO" : "INACTIVO")
            </span>
        </label>
    </div>
    <button class="btn btn-sm btn-outline-info ms-2" @onclick="ForceRefreshAsync" disabled="@_refreshing">
        @(_refreshing ? "⏳" : "🔄 Forzar ciclo")
    </button>
</div>

@* ── Cards resumen ──────────────────────────────────────────────────── *@
<div class="row mb-4 g-3">
    <div class="col-md-2">
        <div class="card bg-dark text-light border-secondary">
            <div class="card-body text-center py-2">
                <div class="small text-muted">Evaluados</div>
                <div class="fs-4 fw-bold">@_snapshot?.EvaluatedCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card bg-dark text-light border-success">
            <div class="card-body text-center py-2">
                <div class="small text-muted">Activos (Top K)</div>
                <div class="fs-4 fw-bold text-success">@_snapshot?.ActiveCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card bg-dark text-light border-warning">
            <div class="card-body text-center py-2">
                <div class="small text-muted">Bloq. Régimen</div>
                <div class="fs-4 fw-bold text-warning">@_snapshot?.BlockedByRegime</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card bg-dark text-light border-danger">
            <div class="card-body text-center py-2">
                <div class="small text-muted">Bloq. Score</div>
                <div class="fs-4 fw-bold text-danger">@_snapshot?.BlockedByScore</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card bg-dark text-light border-info">
            <div class="card-body text-center py-2">
                <div class="small text-muted">Bloq. Cooldown</div>
                <div class="fs-4 fw-bold text-info">@_snapshot?.BlockedByCooldown</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card bg-dark text-light border-secondary">
            <div class="card-body text-center py-2">
                <div class="small text-muted">Zombies elim.</div>
                <div class="fs-4 fw-bold">@_snapshot?.ZombiesRemoved</div>
            </div>
        </div>
    </div>
</div>

@* ── Tabla principal ─────────────────────────────────────────────────── *@
<div class="table-responsive">
    <table class="table table-dark table-hover table-sm align-middle">
        <thead>
            <tr>
                <th>Símbolo</th>
                <th>Score</th>
                <th>Régimen</th>
                <th>Stability</th>
                <th>Activo</th>
                <th>Nuevas Entradas</th>
                <th>Motivo Bloqueo</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (_items is { Count: > 0 })
            {
                @foreach (var item in _items.OrderByDescending(i => i.Score))
                {
                    <tr class="@(item.IsActive ? "table-active" : "")">
                        <td class="fw-bold">@item.Symbol</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="progress flex-grow-1" style="height:8px; background:#2a2a3e;">
                                    <div class="progress-bar" role="progressbar"
                                         style="width:@(item.Score)%; background:@ScoreColor(item.Score);">
                                    </div>
                                </div>
                                <span class="ms-2 small" style="color:@ScoreColor(item.Score); min-width:40px;">
                                    @item.Score.ToString("F1")
                                </span>
                            </div>
                        </td>
                        <td><span class="badge @RegimeBadge(item.Regime)">@item.Regime</span></td>
                        <td>
                            <span class="small" style="color:@StabilityColor(item.RegimeStability)">
                                @item.RegimeStability.ToString("F2")
                            </span>
                        </td>
                        <td>@(item.IsActive ? "✅" : "❌")</td>
                        <td>@(item.AllowNewEntries ? "✅" : "🚫")</td>
                        <td>
                            @if (item.BlockReason is not null)
                            {
                                <span class="badge @BlockReasonBadge(item.BlockReason)">@item.BlockReason</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-light"
                                    @onclick="() => SelectSymbol(item.Symbol)">
                                📈
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="8" class="text-center text-muted py-3">
                    @(_enabled ? "Esperando primer ciclo de evaluación…" : "Pool desactivado")
                </td></tr>
            }
        </tbody>
    </table>
</div>

@* ── Gráfica de velas del símbolo seleccionado ──────────────────────── *@
@if (!string.IsNullOrEmpty(_selectedSymbol))
{
    <div class="mt-4 p-3 rounded" style="background:#1a1a2e;">
        <TradabilityChart Symbol="@_selectedSymbol" />
    </div>
}

@code {
    private bool _enabled;
    private bool _toggling;
    private bool _refreshing;
    private SymbolPoolSnapshotDto? _snapshot;
    private List<SymbolPoolItemDto>? _items;
    private string? _selectedSymbol;
    private HubConnection? _hub;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        await StartSignalRAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var status = await Api.GetSymbolPoolStatusAsync();
            if (status is not null)
                _enabled = status.Enabled;

            _items = await Api.GetSymbolPoolScoresAsync();
        }
        catch { }
    }

    private async Task TogglePoolAsync()
    {
        _toggling = true;
        try
        {
            if (_enabled)
                await Api.DisableSymbolPoolAsync();
            else
                await Api.EnableSymbolPoolAsync();
            _enabled = !_enabled;
        }
        catch { }
        finally { _toggling = false; }
    }

    private async Task ForceRefreshAsync()
    {
        _refreshing = true;
        try
        {
            await Api.ForceRefreshSymbolPoolAsync();
            await Task.Delay(500);
            await LoadDataAsync();
        }
        catch { }
        finally { _refreshing = false; StateHasChanged(); }
    }

    private void SelectSymbol(string symbol) => _selectedSymbol = symbol;

    private async Task StartSignalRAsync()
    {
        try
        {
            var apiUrl = Config["ApiBaseUrl"] ?? "https://localhost:7114";
            _hub = new HubConnectionBuilder()
                .WithUrl($"{apiUrl}/hubs/trading", options =>
                {
                    options.HttpMessageHandlerFactory = innerHandler =>
                        new CookieDelegatingHandler { InnerHandler = innerHandler };
                })
                .WithAutomaticReconnect()
                .Build();

            _hub.On<SymbolPoolSnapshotDto>("OnSymbolPoolUpdate", snapshot =>
            {
                _snapshot = snapshot;
                _items = snapshot.Items;
                _enabled = snapshot.Enabled;
                InvokeAsync(StateHasChanged);
            });

            await _hub.StartAsync();
        }
        catch { }
    }

    private static string ScoreColor(decimal score) => score switch
    {
        >= 70 => "#26a69a",
        >= 40 => "#ffa726",
        _ => "#ef5350"
    };

    private static string RegimeBadge(string regime) => regime switch
    {
        "Trending" => "bg-success",
        "Ranging" => "bg-warning text-dark",
        "Bearish" => "bg-danger",
        "HighVolatility" => "bg-danger",
        "Indefinite" => "bg-dark",
        _ => "bg-secondary"
    };

    private static string StabilityColor(decimal s) => s switch
    {
        >= 0.8m => "#26a69a",
        >= 0.5m => "#ffa726",
        _ => "#ef5350"
    };

    private static string BlockReasonBadge(string reason) => reason switch
    {
        "BelowScoreThreshold" => "bg-danger",
        "NotInTopK" => "bg-warning text-dark",
        "Cooldown" => "bg-info text-dark",
        "IndefiniteRegime" => "bg-dark",
        "UnknownRegime" => "bg-secondary",
        _ => "bg-secondary"
    };

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
        {
            try { await _hub.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
    }
}
