@page "/"
@inject TradingApiClient Api
@inject IConfiguration Config
@implements IAsyncDisposable

<PageTitle>Dashboard — TradingBot</PageTitle>

<h1>📊 Dashboard</h1>

@* ── Banner de desconexión ────────────────────────────────────────────── *@
@if (!apiReachable || hubState != "Connected")
{
    <div class="alert alert-danger py-2 mb-3 d-flex align-items-center">
        <strong class="me-2">⛔ Sin conexión</strong>
        <span>
            @if (!apiReachable) { <span class="badge bg-dark me-1">API inalcanzable</span> }
            @if (hubState != "Connected") { <span class="badge bg-dark">SignalR: @hubState</span> }
        </span>
        <span class="ms-auto small text-muted">Los datos mostrados pueden estar desactualizados</span>
    </div>
}

@* ── Estado del sistema ──────────────────────────────────────────────── *@
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title">Motor</h5>
                @if (systemStatus is null)
                {
                    <p class="text-muted">@(!apiReachable ? "Sin conexión" : "Cargando…")</p>
                }
                else
                {
                    <span class="badge @(systemStatus.IsRunning ? "bg-success" : "bg-warning") fs-6">
                        @(systemStatus.IsRunning ? "🟢 Running" : "🟡 Paused")
                    </span>
                    <div class="mt-2">
                        <button class="btn btn-sm @(systemStatus.IsRunning ? "btn-outline-warning" : "btn-outline-success")"
                                @onclick="ToggleEngineAsync"
                                disabled="@(!apiReachable)">
                            @(systemStatus.IsRunning ? "⏸ Pausar" : "▶ Reanudar")
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title">Conexión</h5>
                @{
                    // La conexión real se determina por: API alcanzable + SignalR conectado + backend reporta WS conectado
                    var wsConnected = apiReachable && hubState == "Connected" && (systemStatus?.IsConnected ?? false);
                    var signalRIssue = hubState != "Connected";
                    var apiIssue = !apiReachable;
                }
                @if (apiIssue)
                {
                    <span class="badge bg-danger fs-6">🔴 API off</span>
                }
                else if (signalRIssue)
                {
                    <span class="badge bg-warning fs-6">🟡 @hubState</span>
                }
                else if (!wsConnected)
                {
                    <span class="badge bg-warning fs-6">🟡 WS off</span>
                }
                else
                {
                    <span class="badge bg-success fs-6">🟢 OK</span>
                }
                <div class="small text-muted mt-1">
                    API: @(apiReachable ? "✓" : "✗") |
                    SR: @(hubState == "Connected" ? "✓" : "✗") |
                    WS: @(systemStatus?.IsConnected == true ? "✓" : "✗")
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title">Estrategias</h5>
                <span class="fs-3 fw-bold">@(systemStatus?.Strategies?.Count ?? 0)</span>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title">P&amp;L diario</h5>
                @if (pnlSummaries is null)
                {
                    <p class="text-muted">—</p>
                }
                else
                {
                    var totalDaily = pnlSummaries.Sum(p => p.DailyRealizedPnL);
                    var totalUnrealized = pnlSummaries.Sum(p => p.UnrealizedPnL);
                    <span class="fs-4 fw-bold @(totalDaily >= 0 ? "text-success" : "text-danger")">
                        @totalDaily.ToString("F2") USDT
                    </span>
                    <div class="small text-muted mt-1">
                        No realizado: <span class="@(totalUnrealized >= 0 ? "text-success" : "text-danger")">
                            @totalUnrealized.ToString("F2")
                        </span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* ── Balance de cuenta ────────────────────────────────────────────────── *@
@if (accountBalances?.Count > 0)
{
    <div class="row mb-4">
        @foreach (var b in accountBalances.Take(6))
        {
            <div class="col-md-2 mb-2">
                <div class="card">
                    <div class="card-body py-2 text-center">
                        <strong>@b.Asset</strong>
                        <div class="fs-5">@b.Free.ToString("N4")</div>
                        @if (b.Locked > 0)
                        {
                            <small class="text-muted">🔒 @b.Locked.ToString("N4")</small>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@* ── Exposición del portafolio ───────────────────────────────────────── *@
@if (portfolioExposure is not null && portfolioExposure.BySymbol.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>📊 Exposición del Portafolio</strong>
            @if (portfolioExposure.DrawdownTriggered)
            {
                <span class="badge bg-danger">🛑 Drawdown @portfolioExposure.DrawdownPercent.ToString("N1")%</span>
            }
        </div>
        <div class="card-body py-2">
            <div class="row mb-2">
                <div class="col-md-4 text-center">
                    <small class="text-muted">Long</small>
                    <div class="fs-5 text-success">@portfolioExposure.TotalLongUsdt.ToString("N2") USDT</div>
                </div>
                <div class="col-md-4 text-center">
                    <small class="text-muted">Short</small>
                    <div class="fs-5 text-danger">@portfolioExposure.TotalShortUsdt.ToString("N2") USDT</div>
                </div>
                <div class="col-md-4 text-center">
                    <small class="text-muted">Neto</small>
                    <div class="fs-5 @(portfolioExposure.NetUsdt >= 0 ? "text-success" : "text-danger")">
                        @((portfolioExposure.NetUsdt >= 0 ? "+" : "") + portfolioExposure.NetUsdt.ToString("N2")) USDT
                    </div>
                </div>
            </div>
            @foreach (var sym in portfolioExposure.BySymbol)
            {
                var total = portfolioExposure.TotalLongUsdt + portfolioExposure.TotalShortUsdt;
                var pct = total > 0 ? (sym.LongUsdt + sym.ShortUsdt) / total * 100 : 0;
                <div class="d-flex justify-content-between align-items-center small border-top py-1">
                    <strong>@sym.Symbol</strong>
                    <div>
                        <span class="text-success me-2">L: @sym.LongUsdt.ToString("N2")</span>
                        <span class="text-danger me-2">S: @sym.ShortUsdt.ToString("N2")</span>
                        <span class="badge bg-secondary">@pct.ToString("N0")%</span>
                    </div>
                </div>
            }
        </div>
    </div>
}

@* ── P&L por estrategia ─────────────────────────────────────────────── *@
@if (pnlSummaries?.Count > 0)
{
    <div class="row mb-4">
        @foreach (var pnl in pnlSummaries)
        {
            <div class="col-md-4 mb-2">
                <div class="card">
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@pnl.StrategyName</strong>
                                <span class="text-muted small ms-1">@pnl.Symbol</span>
                            </div>
                            <span class="badge bg-secondary">@pnl.OpenPositions pos</span>
                        </div>
                        <div class="d-flex justify-content-between mt-1 small">
                            <span>Hoy: <strong class="@(pnl.DailyRealizedPnL >= 0 ? "text-success" : "text-danger")">@pnl.DailyRealizedPnL.ToString("F2")</strong></span>
                            <span>Total: <strong class="@(pnl.TotalRealizedPnL >= 0 ? "text-success" : "text-danger")">@pnl.TotalRealizedPnL.ToString("F2")</strong></span>
                            <span>Open: <strong class="@(pnl.UnrealizedPnL >= 0 ? "text-success" : "text-danger")">@pnl.UnrealizedPnL.ToString("F2")</strong></span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* ── Eventos recientes (SignalR) ─────────────────────────────────────── *@
<div class="row mb-4">
    <div class="col-md-6">
        <h5>📡 Señales recientes</h5>
        @if (recentSignals.Count == 0)
        {
            <p class="text-muted small">Esperando señales…</p>
        }
        else
        {
            <div class="list-group list-group-flush" style="max-height:200px;overflow-y:auto">
                @foreach (var sig in recentSignals)
                {
                    <div class="list-group-item py-1 px-2 small d-flex justify-content-between">
                        <span>
                            <span class="badge @(sig.Side == "Buy" ? "bg-success" : "bg-danger") me-1">@sig.Side</span>
                            <strong>@sig.Symbol</strong>
                        </span>
                        <span class="text-muted">@sig.Time</span>
                    </div>
                }
            </div>
        }
    </div>
    <div class="col-md-6">
        <h5>📋 Órdenes recientes</h5>
        @if (recentOrders.Count == 0)
        {
            <p class="text-muted small">Esperando órdenes…</p>
        }
        else
        {
            <div class="list-group list-group-flush" style="max-height:200px;overflow-y:auto">
                @foreach (var ord in recentOrders)
                {
                    <div class="list-group-item py-1 px-2 small d-flex justify-content-between">
                        <span>
                            <span class="badge @(ord.Side == "Buy" ? "bg-success" : "bg-danger") me-1">@ord.Side</span>
                            <strong>@ord.Symbol</strong>
                            <span class="text-muted ms-1">@ord.Quantity qty</span>
                            @if (ord.IsPaper) { <span class="badge bg-info ms-1">Paper</span> }
                        </span>
                        <span class="text-muted">@ord.Time</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

@* ── Ticks en tiempo real ────────────────────────────────────────────── *@
<h5>
    📡 Ticks en tiempo real
    @if (hubState == "Connected")
    {
        <span class="badge bg-success ms-2 small">SignalR ✓</span>
    }
    else if (hubState == "Reconnecting…")
    {
        <span class="badge bg-warning ms-2 small">Reconectando…</span>
    }
    else
    {
        <span class="badge bg-danger ms-2 small">@hubState</span>
    }
</h5>

@if (hubState != "Connected")
{
    <p class="text-muted">⚠ Sin conexión SignalR — los ticks se reanudarán al reconectar.</p>
}
else if (recentTicks.Count == 0)
{
    <p class="text-muted">Esperando ticks…</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Hora</th>
                    <th>Símbolo</th>
                    <th>Precio</th>
                    <th>Bid</th>
                    <th>Ask</th>
                    <th>Volumen</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tick in recentTicks)
                {
                    <tr>
                        <td>@tick.Timestamp.ToLocalTime().ToString("HH:mm:ss.fff")</td>
                        <td><strong>@tick.Symbol</strong></td>
                        <td>@tick.LastPrice.ToString("N2")</td>
                        <td>@tick.BidPrice.ToString("N2")</td>
                        <td>@tick.AskPrice.ToString("N2")</td>
                        <td>@tick.Volume.ToString("N4")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@* ── Estrategias activas ────────────────────────────────────────────── *@
@if (systemStatus?.Strategies?.Any() == true)
{
    <h5 class="mt-3">🎯 Estado por estrategia</h5>
    <div class="table-responsive">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Estrategia</th>
                    <th>Símbolo</th>
                    <th>Estado</th>
                    <th>Ticks</th>
                    <th>Señales</th>
                    <th>Órdenes</th>
                    <th>Último tick</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var kv in systemStatus.Strategies)
                {
                    var s = kv.Value;
                    <tr>
                        <td>@s.StrategyName</td>
                        <td>@s.Symbol</td>
                        <td>
                            <span class="badge @(s.IsProcessing ? "bg-success" : "bg-secondary")">
                                @(s.IsProcessing ? "Procesando" : "Detenida")
                            </span>
                        </td>
                        <td>@s.TicksProcessed.ToString("N0")</td>
                        <td>@s.SignalsGenerated</td>
                        <td>@s.OrdersPlaced</td>
                        <td>@(s.LastTickAt == default ? "—" : s.LastTickAt.ToLocalTime().ToString("HH:mm:ss"))</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@* ── Toast de alertas ────────────────────────────────────────────────── *@
@if (toastMessages.Count > 0)
{
    <div style="position:fixed;bottom:20px;right:20px;z-index:9999;max-width:400px">
        @foreach (var toast in toastMessages)
        {
            <div class="alert @toast.CssClass alert-dismissible fade show py-2 mb-2 shadow" role="alert">
                <small>@toast.Message</small>
                <button type="button" class="btn-close btn-sm" @onclick="() => DismissToast(toast)"></button>
            </div>
        }
    </div>
}

@if (errorMessage is not null)
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@code {
    private SystemStatusDto? systemStatus;
    private List<PnLSummaryDto>? pnlSummaries;
    private List<AccountBalanceDto>? accountBalances;
    private PortfolioExposureDto? portfolioExposure;
    private HubConnection? hubConnection;
    private string hubState = "Disconnected";
    private string? errorMessage;
    private bool apiReachable = true;
    private int _consecutiveApiFailures;
    private readonly List<MarketTickDto> recentTicks = [];
    private readonly List<SignalEntry> recentSignals = [];
    private readonly List<OrderEntry> recentOrders = [];
    private readonly List<ToastMessage> toastMessages = [];
    private const int MaxTicks = 20;
    private const int MaxEvents = 10;
    private System.Threading.Timer? _refreshTimer;

    /// <summary>Computed: true si tanto la API como SignalR están conectados.</summary>
    private bool IsFullyConnected => apiReachable && hubState == "Connected";

    protected override async Task OnInitializedAsync()
    {
        await LoadStatusAsync();
        await LoadPnLAsync();
        await LoadBalanceAsync();
        await LoadExposureAsync();
        await StartSignalRAsync();

        // Refrescar P&L y status cada 15 segundos (antes 30)
        _refreshTimer = new System.Threading.Timer(
            async _ => await InvokeAsync(async () =>
            {
                await LoadStatusAsync();
                await LoadPnLAsync();
                await LoadBalanceAsync();
                await LoadExposureAsync();
                StateHasChanged();
            }),
            null,
            TimeSpan.FromSeconds(15),
            TimeSpan.FromSeconds(15));
    }

    private async Task LoadStatusAsync()
    {
        try
        {
            systemStatus = await Api.GetSystemStatusAsync();
            errorMessage = null;
            apiReachable = true;
            _consecutiveApiFailures = 0;
        }
        catch (Exception ex)
        {
            _consecutiveApiFailures++;
            apiReachable = false;

            // Limpiar estado para no mostrar datos obsoletos
            systemStatus = null;
            pnlSummaries = null;

            if (_consecutiveApiFailures >= 2)
                errorMessage = $"⛔ Sin conexión con la API ({_consecutiveApiFailures} intentos fallidos). Último error: {ex.Message}";
            else
                errorMessage = $"Error al obtener estado: {ex.Message}";
        }
    }

    private async Task LoadPnLAsync()
    {
        try
        {
            if (!apiReachable) return;
            pnlSummaries = await Api.GetPnLSummaryAsync();
        }
        catch
        {
            // P&L es informativo; no bloquear la UI si falla
        }
    }

    private async Task LoadBalanceAsync()
    {
        try
        {
            if (!apiReachable) return;
            accountBalances = await Api.GetBalanceAsync();
        }
        catch
        {
            // Balance es informativo; no bloquear la UI si falla
        }
    }

    private async Task LoadExposureAsync()
    {
        try
        {
            if (!apiReachable) return;
            portfolioExposure = await Api.GetPortfolioExposureAsync();
        }
        catch
        {
            // Exposición es informativa; no bloquear la UI si falla
        }
    }

    private async Task StartSignalRAsync()
    {
        try
        {
            var apiUrl = Config["ApiBaseUrl"] ?? "https://localhost:7114";

            var hubApiKey = Config["ApiKey"] ?? string.Empty;
            hubConnection = new HubConnectionBuilder()
                .WithUrl($"{apiUrl}/hubs/trading", options =>
                {
                    if (!string.IsNullOrWhiteSpace(hubApiKey))
                    {
                        // HTTP transports (negotiate, SSE, long-polling): header personalizado
                        options.Headers.Add("X-Api-Key", hubApiKey);
                        // WebSocket: los navegadores no pueden enviar headers en WS upgrades;
                        // SignalR añade automáticamente ?access_token=<key> en la URL del WS
                        options.AccessTokenProvider = () => Task.FromResult<string?>(hubApiKey);
                    }
                })
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<MarketTickDto>("OnMarketTick", tick =>
            {
                recentTicks.Insert(0, tick);
                if (recentTicks.Count > MaxTicks)
                    recentTicks.RemoveAt(recentTicks.Count - 1);
                InvokeAsync(StateHasChanged);
            });

            hubConnection.On<SignalDto>("OnSignalGenerated", signal =>
            {
                recentSignals.Insert(0, new SignalEntry(
                    signal.Symbol, signal.Direction,
                    DateTimeOffset.Now.ToLocalTime().ToString("HH:mm:ss")));
                if (recentSignals.Count > MaxEvents)
                    recentSignals.RemoveAt(recentSignals.Count - 1);
                AddToast($"📈 Señal {signal.Direction} en {signal.Symbol}", "alert-info");
                InvokeAsync(StateHasChanged);
            });

            hubConnection.On<OrderExecutedDto>("OnOrderExecuted", order =>
            {
                recentOrders.Insert(0, new OrderEntry(
                    order.Symbol, order.Side, order.Quantity,
                    order.IsPaperTrade,
                    DateTimeOffset.Now.ToLocalTime().ToString("HH:mm:ss")));
                if (recentOrders.Count > MaxEvents)
                    recentOrders.RemoveAt(recentOrders.Count - 1);
                AddToast(
                    $"✅ Orden {order.Side} {order.Quantity} {order.Symbol}" +
                    (order.IsPaperTrade ? " (Paper)" : ""),
                    "alert-success");
                InvokeAsync(StateHasChanged);
            });

            hubConnection.On<string>("OnAlert", message =>
            {
                AddToast($"⚠ {message}", "alert-warning");
                InvokeAsync(StateHasChanged);
            });

            hubConnection.Reconnecting += _ =>
            {
                hubState = "Reconnecting…";
                AddToast("🔄 SignalR reconectando…", "alert-warning");
                InvokeAsync(StateHasChanged);
                return Task.CompletedTask;
            };

            hubConnection.Reconnected += _ =>
            {
                hubState = "Connected";
                AddToast("✅ SignalR reconectado", "alert-success");
                InvokeAsync(StateHasChanged);
                return Task.CompletedTask;
            };

            hubConnection.Closed += _ =>
            {
                hubState = "Disconnected";
                recentTicks.Clear();
                AddToast("❌ SignalR desconectado — los ticks se detendrán", "alert-danger");
                InvokeAsync(StateHasChanged);
                return Task.CompletedTask;
            };

            // Retry con backoff exponencial para la conexión inicial
            const int maxRetries = 5;
            for (var attempt = 0; attempt < maxRetries; attempt++)
            {
                try
                {
                    await hubConnection.StartAsync();
                    hubState = "Connected";
                    return;
                }
                catch when (attempt < maxRetries - 1)
                {
                    var delay = TimeSpan.FromSeconds(Math.Pow(2, attempt));
                    hubState = $"Retry {attempt + 1}/{maxRetries}…";
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(delay);
                }
            }

            hubState = "Error";
            errorMessage = "SignalR: no se pudo conectar después de varios intentos.";
        }
        catch (Exception ex)
        {
            hubState = "Error";
            errorMessage = $"SignalR: {ex.Message}";
        }
    }

    private async Task ToggleEngineAsync()
    {
        try
        {
            if (systemStatus?.IsRunning == true)
                await Api.PauseAsync();
            else
                await Api.ResumeAsync();

            await LoadStatusAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }

    private void AddToast(string message, string cssClass)
    {
        var toast = new ToastMessage(message, cssClass);
        toastMessages.Insert(0, toast);
        if (toastMessages.Count > 5)
            toastMessages.RemoveAt(toastMessages.Count - 1);

        // Auto-dismiss after 8 seconds
        _ = Task.Delay(8000).ContinueWith(_ => InvokeAsync(() =>
        {
            toastMessages.Remove(toast);
            StateHasChanged();
        }));
    }

    private void DismissToast(ToastMessage toast) => toastMessages.Remove(toast);

    public async ValueTask DisposeAsync()
    {
        _refreshTimer?.Dispose();
        if (hubConnection is not null)
            await hubConnection.DisposeAsync();
    }

    // ── DTOs internos para SignalR ────────────────────────────────────────

    private sealed record SignalEntry(string Symbol, string Side, string Time);
    private sealed record OrderEntry(string Symbol, string Side, decimal Quantity, bool IsPaper, string Time);
    private sealed record ToastMessage(string Message, string CssClass);

    private sealed record SignalDto(string Symbol, string Direction);
    private sealed record OrderExecutedDto(string Symbol, string Side, decimal Quantity, bool IsPaperTrade);
}
