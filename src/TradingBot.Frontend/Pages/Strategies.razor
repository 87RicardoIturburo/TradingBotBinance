@page "/strategies"
@inject TradingApiClient Api

<PageTitle>Estrategias — TradingBot</PageTitle>

<h1>🎯 Estrategias</h1>

@* ── Plantillas predefinidas ─────────────────────────────────────────── *@
@if (templates is not null && templates.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header" role="button" @onclick="() => showTemplates = !showTemplates">
            📋 Crear desde plantilla @(showTemplates ? "▲" : "▼")
        </div>
        @if (showTemplates)
        {
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var tpl in templates)
                    {
                        <div class="col-md-6 col-lg-3">
                            <div class="card h-100 border-primary">
                                <div class="card-body">
                                    <h6 class="card-title">@tpl.Name</h6>
                                    <p class="card-text small text-muted">@tpl.Description</p>
                                    <div class="mb-2">
                                        <span class="badge bg-info me-1">@tpl.Symbol</span>
                                        @foreach (var ind in tpl.Indicators)
                                        {
                                            <span class="badge bg-secondary me-1">@ind.Type</span>
                                        }
                                    </div>
                                    <small class="text-muted">@tpl.Rules.Count reglas · SL @tpl.RiskConfig.StopLossPercent% · TP @tpl.RiskConfig.TakeProfitPercent%</small>
                                </div>
                                <div class="card-footer bg-transparent">
                                    <button class="btn btn-sm btn-outline-primary w-100" @onclick="() => ApplyTemplateAsync(tpl)">
                                        🚀 Crear con esta plantilla
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@* ── Formulario de creación ──────────────────────────────────────────── *@
<div class="card mb-4">
    <div class="card-header" role="button" @onclick="() => showForm = !showForm">
        ➕ Nueva estrategia @(showForm ? "▲" : "▼")
    </div>
    @if (showForm)
    {
        <div class="card-body">
            <EditForm Model="newStrategy" OnValidSubmit="CreateStrategyAsync" FormName="createStrategy">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Nombre</label>
                        <InputText class="form-control" @bind-Value="newStrategy.Name" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Símbolo</label>
                        <SymbolSelector @bind-Value="newStrategy.Symbol" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Modo</label>
                        <InputSelect class="form-select" @bind-Value="newStrategy.Mode">
                            <option value="PaperTrading">Paper Trading</option>
                            <option value="Testnet">Testnet</option>
                            <option value="Live">Live</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Max Orden (USDT)</label>
                        <InputNumber class="form-control" @bind-Value="newStrategy.MaxOrderAmountUsdt" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Max Pérdida Diaria</label>
                        <InputNumber class="form-control" @bind-Value="newStrategy.MaxDailyLossUsdt" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Stop Loss %</label>
                        <InputNumber class="form-control" @bind-Value="newStrategy.StopLossPercent" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Take Profit %</label>
                        <InputNumber class="form-control" @bind-Value="newStrategy.TakeProfitPercent" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Max Posiciones</label>
                        <InputNumber class="form-control" @bind-Value="newStrategy.MaxOpenPositions" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Descripción</label>
                        <InputText class="form-control" @bind-Value="newStrategy.Description" />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary mt-3" disabled="@isSubmitting">
                    @(isSubmitting ? "Creando…" : "Crear estrategia")
                </button>
            </EditForm>
        </div>
    }
</div>

@* ── Lista de estrategias ────────────────────────────────────────────── *@
@if (isLoading)
{
    <p class="text-muted">Cargando estrategias…</p>
}
else if (strategies is null || strategies.Count == 0)
{
    <div class="alert alert-info">No hay estrategias configuradas. Crea una arriba.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Símbolo</th>
                    <th>Estado</th>
                    <th>Modo</th>
                    <th>Max Orden</th>
                    <th>SL / TP</th>
                    <th>Reglas</th>
                    <th>Creada</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in strategies)
                {
                    <tr>
                        <td>
                            <a href="/strategies/@s.Id"><strong>@s.Name</strong></a>
                            @if (s.Origin is "Pool" or "AutoPilotV1")
                            {
                                <span class="badge bg-warning text-dark ms-1">@s.Origin</span>
                            }
                            @if (!string.IsNullOrEmpty(s.Description))
                            {
                                <br /><small class="text-muted">@s.Description</small>
                            }
                        </td>
                        <td>@s.Symbol</td>
                        <td>
                            <span class="badge @GetStatusBadgeClass(s.Status)">@s.Status</span>
                        </td>
                        <td><span class="badge bg-info">@s.Mode</span></td>
                        <td>@s.RiskConfig.MaxOrderAmountUsdt.ToString("N2") USDT</td>
                        <td>@s.RiskConfig.StopLossPercent% / @s.RiskConfig.TakeProfitPercent%</td>
                        <td>@s.Rules.Count</td>
                        <td>@s.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</td>
                        <td>
                            @if (s.Status == "Active")
                            {
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => DeactivateAsync(s.Id)">
                                    ⏸ Desactivar
                                </button>
                            }
                            else
                            {
                                @if (s.Origin is not "Pool")
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => ActivateAsync(s.Id)">
                                        ▶ Activar
                                    </button>
                                }
                                <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => ConfirmDeleteAsync(s)">
                                    🗑
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (errorMessage is not null)
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@code {
    private List<StrategyDto>? strategies;
    private List<StrategyTemplateDto>? templates;
    private bool isLoading = true;
    private bool isSubmitting;
    private bool showForm;
    private bool showTemplates;
    private string? errorMessage;

    private StrategyFormModel newStrategy = new();

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadStrategiesAsync(), LoadTemplatesAsync());
    }

    private async Task LoadTemplatesAsync()
    {
        try
        {
            templates = await Api.GetTemplatesAsync();
        }
        catch
        {
            // Las plantillas son opcionales; si falla, no bloquea la página
        }
    }

    private async Task LoadStrategiesAsync()
    {
        isLoading = true;
        try
        {
            strategies = await Api.GetStrategiesAsync();
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar estrategias: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateStrategyAsync()
    {
        isSubmitting = true;
        errorMessage = null;
        try
        {
            var request = new CreateStrategyRequest(
                newStrategy.Name, newStrategy.Symbol, newStrategy.Mode,
                newStrategy.MaxOrderAmountUsdt, newStrategy.MaxDailyLossUsdt,
                newStrategy.StopLossPercent, newStrategy.TakeProfitPercent,
                newStrategy.MaxOpenPositions, newStrategy.Description);

            await Api.CreateStrategyAsync(request);
            newStrategy = new();
            showForm = false;
            await LoadStrategiesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al crear: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task ActivateAsync(Guid id)
    {
        try
        {
            await Api.ActivateStrategyAsync(id);
            await LoadStrategiesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al activar: {ex.Message}";
        }
    }

    private async Task DeactivateAsync(Guid id)
    {
        try
        {
            await Api.DeactivateStrategyAsync(id);
            await LoadStrategiesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al desactivar: {ex.Message}";
        }
    }

    private async Task DeleteAsync(Guid id)
    {
        try
        {
            await Api.DeleteStrategyAsync(id);
            await LoadStrategiesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al eliminar: {ex.Message}";
        }
    }

    private async Task ConfirmDeleteAsync(StrategyDto strategy)
    {
        if (strategy.Origin is "Pool")
        {
            try
            {
                await Api.ExcludePoolSymbolAsync(strategy.Symbol);
            }
            catch
            {
                // Blacklist es best-effort
            }
        }

        await DeleteAsync(strategy.Id);
    }

    private async Task ApplyTemplateAsync(StrategyTemplateDto tpl)
    {
        isSubmitting = true;
        errorMessage = null;
        try
        {
            var rc = tpl.RiskConfig;
            var createRequest = new CreateStrategyRequest(
                tpl.Name, tpl.Symbol, "PaperTrading",
                rc.MaxOrderAmountUsdt, rc.MaxDailyLossUsdt,
                rc.StopLossPercent, rc.TakeProfitPercent,
                rc.MaxOpenPositions, tpl.Description,
                rc.UseAtrSizing, rc.RiskPercentPerTrade, rc.AtrMultiplier,
                rc.Timeframe, rc.ConfirmationTimeframe);

            var created = await Api.CreateStrategyAsync(createRequest);
            if (created is null) return;

            // 2. Agregar indicadores
            foreach (var ind in tpl.Indicators)
            {
                await Api.AddIndicatorAsync(created.Id, new AddIndicatorRequest(ind.Type, ind.Parameters));
            }

            // 3. Agregar reglas
            foreach (var rule in tpl.Rules)
            {
                var conditions = rule.Conditions
                    .Select(c => new AddRuleConditionRequest(c.Indicator, c.Comparator, c.Value))
                    .ToList();
                await Api.AddRuleAsync(created.Id, new AddRuleRequest(
                    rule.Name, rule.RuleType, rule.Operator,
                    conditions, rule.ActionType, rule.AmountUsdt));
            }

            showTemplates = false;
            await LoadStrategiesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al crear desde plantilla: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Active"   => "bg-success",
        "Inactive" => "bg-secondary",
        "Paused"   => "bg-warning text-dark",
        "Error"    => "bg-danger",
        _          => "bg-secondary"
    };

    private sealed class StrategyFormModel
    {
        public string  Name                = string.Empty;
        public string  Symbol              = "BTCUSDT";
        public string  Mode                = "PaperTrading";
        public decimal MaxOrderAmountUsdt  = 100m;
        public decimal MaxDailyLossUsdt    = 500m;
        public decimal StopLossPercent     = 2m;
        public decimal TakeProfitPercent   = 4m;
        public int     MaxOpenPositions    = 3;
        public string? Description;
    }
}
